<?xml version="1.0"?>
<!--
  Phoebe dual UR5e arms — standalone MuJoCo model for CERG.

  This is a mesh-free excerpt of the full phoebe.xml from
  NASA-JSC-Robotics/phoebe_bridgeback_ws.  All inertial parameters
  and joint kinematics are taken verbatim from that file; only the
  mesh geoms have been replaced with capsule/cylinder primitives.

  DOFs: 12 revolute joints (6 left + 6 right UR5e arm).
  Joint order: left_shoulder_pan, left_shoulder_lift, left_elbow,
               left_wrist_1, left_wrist_2, left_wrist_3,
               right_shoulder_pan, right_shoulder_lift, right_elbow,
               right_wrist_1, right_wrist_2, right_wrist_3

  Arms are mounted at their nominal world positions with the lift
  columns fixed at h = 0.24 m (the initial_value from the ROS 2
  control config), so:
    left  mount origin : (0,  0.201, 0.85)
    right mount origin : (0, -0.201, 0.85)

  No actuator elements — CERG applies torques via mj_data.qfrc_applied.
-->
<mujoco model="phoebe_dual_arms">
  <compiler angle="radian" fusestatic="false"/>

  <option gravity="0 0 -9.81" timestep="0.001"/>

  <default>
    <geom rgba="0.49 0.68 0.80 1" type="capsule"/>
  </default>

  <worldbody>
    <!-- ─── LEFT ARM MOUNT (lift column fixed at h=0.24 m) ─── -->
    <body name="left_arm_mount" pos="0 0.201 0.85">

      <body name="left_ur_arm_shoulder_link"
            pos="0.0126802 0.124615 0.463459"
            quat="0.353086 -0.134633 0.350748 0.856843">
        <inertial pos="0 -0.00193 -0.02561"
                  quat="0.560239 0.250606 -0.316559 0.72327"
                  mass="3.761"
                  diaginertia="0.00703079 0.0070003 0.00602478"/>
        <joint name="left_ur_arm_shoulder_pan_joint"
               type="hinge" axis="0 0 1"
               range="-6.28319 6.28319"
               actuatorfrcrange="-150 150"/>
        <geom type="sphere" size="0.06" rgba="0.49 0.68 0.80 1"/>

        <body name="left_ur_arm_upper_arm_link"
              pos="0.000226782 0 0"
              quat="0.707115 0.707098 -9.55133e-07 -9.55157e-07">
          <inertial pos="-0.2125 0 0.11336"
                    quat="0.500275 0.499641 0.500368 0.499716"
                    mass="8.058"
                    diaginertia="0.333881 0.332472 0.0150588"/>
          <joint name="left_ur_arm_shoulder_lift_joint"
                 type="hinge" axis="0 0 1"
                 range="-6.28319 6.28319"
                 actuatorfrcrange="-150 150"/>
          <geom fromto="0 0 0 -0.4255 0 0" size="0.04"/>

          <body name="left_ur_arm_forearm_link"
                pos="-0.425505 0 0"
                quat="1 2.07226e-05 -0.000262987 -7.61405e-08">
            <inertial pos="-0.2422 0 0.0265"
                      quat="0.501301 0.498381 0.510711 0.489375"
                      mass="2.846"
                      diaginertia="0.0787927 0.0785102 0.00397103"/>
            <joint name="left_ur_arm_elbow_joint"
                   type="hinge" axis="0 0 1"
                   range="-3.14159 3.14159"
                   actuatorfrcrange="-150 150"/>
            <geom fromto="0 0 0 -0.3926 0 0" size="0.033"/>

            <body name="left_ur_arm_wrist_1_link"
                  pos="-0.392582 -4.63122e-05 0.133721"
                  quat="1 0.000173166 0.000544517 1.77883e-06">
              <inertial pos="0 -0.01634 -0.0018"
                        quat="0.960609 0.277707 0.00515042 -0.00913626"
                        mass="1.37"
                        diaginertia="0.00165502 0.00142363 0.00119868"/>
              <joint name="left_ur_arm_wrist_1_joint"
                     type="hinge" axis="0 0 1"
                     range="-6.28319 6.28319"
                     actuatorfrcrange="-28 28"/>
              <geom fromto="0 0 0 0 -0.1 0" size="0.028"/>

              <body name="left_ur_arm_wrist_2_link"
                    pos="1.36989e-05 -0.0999777 8.48591e-05"
                    quat="0.707407 0.706807 -4.64337e-08 -4.64731e-08">
                <inertial pos="0 0.01634 -0.0018"
                          quat="0.996652 -0.0779336 -0.00684629 -0.0237381"
                          mass="1.3"
                          diaginertia="0.00135637 0.00128607 0.00095814"/>
                <joint name="left_ur_arm_wrist_2_joint"
                       type="hinge" axis="0 0 1"
                       range="-6.28319 6.28319"
                       actuatorfrcrange="-28 28"/>
                <geom fromto="0 0 0 0 0.1 0" size="0.028"/>

                <body name="left_ur_arm_wrist_3_link"
                      pos="0.000106733 0.0996158 1.94962e-05"
                      quat="-0.707176 0.707038 1.93623e-08 -1.93661e-08">
                  <inertial pos="0.000839754 -0.00316796 0.065463"
                            quat="0.724907 0.688778 0.0074684 0.00631936"
                            mass="1.31087"
                            diaginertia="0.00765268 0.0049038 0.00405629"/>
                  <joint name="left_ur_arm_wrist_3_joint"
                         type="hinge" axis="0 0 1"
                         range="-6.28319 6.28319"
                         actuatorfrcrange="-28 28"/>
                  <geom type="sphere" size="0.04" rgba="0.9 0.5 0.1 1"/>
                  <!-- tool0 site for FK queries -->
                  <site name="left_ur_arm_tool0" pos="0 0 0.1" size="0.01"/>
                </body>

              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- ─── RIGHT ARM MOUNT (lift column fixed at h=0.24 m) ─── -->
    <body name="right_arm_mount" pos="0 -0.201 0.85">

      <body name="right_ur_arm_shoulder_link"
            pos="0.0147855 -0.128643 0.461404"
            quat="0.857772 0.353915 -0.131976 0.348645">
        <inertial pos="0 -0.00193 -0.02561"
                  quat="0.560239 0.250606 -0.316559 0.72327"
                  mass="3.761"
                  diaginertia="0.00703079 0.0070003 0.00602478"/>
        <joint name="right_ur_arm_shoulder_pan_joint"
               type="hinge" axis="0 0 1"
               range="-6.28319 6.28319"
               actuatorfrcrange="-150 150"/>
        <geom type="sphere" size="0.06" rgba="0.49 0.68 0.80 1"/>

        <body name="right_ur_arm_upper_arm_link"
              pos="7.08681e-05 0 0"
              quat="0.707305 0.706908 1.4235e-06 1.4243e-06">
          <inertial pos="-0.2125 0 0.11336"
                    quat="0.500275 0.499641 0.500368 0.499716"
                    mass="8.058"
                    diaginertia="0.333881 0.332472 0.0150588"/>
          <joint name="right_ur_arm_shoulder_lift_joint"
                 type="hinge" axis="0 0 1"
                 range="-6.28319 6.28319"
                 actuatorfrcrange="-150 150"/>
          <geom fromto="0 0 0 -0.4253 0 0" size="0.04"/>

          <body name="right_ur_arm_forearm_link"
                pos="-0.425304 0 0"
                quat="1 9.70614e-05 0.000269354 4.69205e-07">
            <inertial pos="-0.2422 0 0.0265"
                      quat="0.501301 0.498381 0.510711 0.489375"
                      mass="2.846"
                      diaginertia="0.0787927 0.0785102 0.00397103"/>
            <joint name="right_ur_arm_elbow_joint"
                   type="hinge" axis="0 0 1"
                   range="-3.14159 3.14159"
                   actuatorfrcrange="-150 150"/>
            <geom fromto="0 0 0 -0.3922 0 0" size="0.033"/>

            <body name="right_ur_arm_wrist_1_link"
                  pos="-0.392184 8.85386e-05 0.134008"
                  quat="1 -0.000330347 0.000508859 -1.44648e-06">
              <inertial pos="0 -0.01634 -0.0018"
                        quat="0.960609 0.277707 0.00515042 -0.00913626"
                        mass="1.37"
                        diaginertia="0.00165502 0.00142363 0.00119868"/>
              <joint name="right_ur_arm_wrist_1_joint"
                     type="hinge" axis="0 0 1"
                     range="-6.28319 6.28319"
                     actuatorfrcrange="-28 28"/>
              <geom fromto="0 0 0 0 -0.1 0" size="0.028"/>

              <body name="right_ur_arm_wrist_2_link"
                    pos="3.88504e-05 -0.0998073 8.22332e-05"
                    quat="0.707398 0.706815 2.04332e-07 2.045e-07">
                <inertial pos="0 0.01634 -0.0018"
                          quat="0.996652 -0.0779336 -0.00684629 -0.0237381"
                          mass="1.3"
                          diaginertia="0.00135637 0.00128607 0.00095814"/>
                <joint name="right_ur_arm_wrist_2_joint"
                       type="hinge" axis="0 0 1"
                       range="-6.28319 6.28319"
                       actuatorfrcrange="-28 28"/>
                <geom fromto="0 0 0 0 0.1 0" size="0.028"/>

                <body name="right_ur_arm_wrist_3_link"
                      pos="7.98405e-05 0.0996341 1.16486e-05"
                      quat="-0.707148 0.707065 4.07248e-09 -4.07295e-09">
                  <inertial pos="0.000681263 -0.00313372 0.0653098"
                            quat="0.720299 0.693617 0.00574545 0.00567072"
                            mass="1.31087"
                            diaginertia="0.00764365 0.00489151 0.00404757"/>
                  <joint name="right_ur_arm_wrist_3_joint"
                         type="hinge" axis="0 0 1"
                         range="-6.28319 6.28319"
                         actuatorfrcrange="-28 28"/>
                  <geom type="sphere" size="0.04" rgba="0.9 0.3 0.1 1"/>
                  <!-- tool0 site for FK queries -->
                  <site name="right_ur_arm_tool0" pos="0 0 0.1" size="0.01"/>
                </body>

              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

  </worldbody>
</mujoco>
